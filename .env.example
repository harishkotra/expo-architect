# Expo Architect environment template
# Copy this file to .env and fill in real values before running `npm run web`.

# LLM provider (set at least one)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional fallback provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Resend email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL="Expo Architect <onboarding@resend.dev>"
